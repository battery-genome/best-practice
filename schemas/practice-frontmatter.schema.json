{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/battinfo/schemas/practice-frontmatter.schema.json",
  "title": "Best practice frontmatter",
  "description": "Structured metadata carried in the YAML frontmatter of each practice.md. Validated by scripts/build_manifest.py and CI.",
  "type": "object",
  "required": ["id", "title", "summary", "version", "status", "applies_to", "maturity", "authors", "sources"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "description": "Stable identifier: 'practice:' followed by the folder slug. An opaque canonical UID is minted later at registry publication; this id never changes.",
      "type": "string",
      "pattern": "^practice:[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "summary": {
      "description": "One-sentence summary used in listings and search results.",
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "version": {
      "description": "Semantic version of this practice document. Bump on any normative change.",
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "published", "superseded"]
    },
    "superseded_by": {
      "description": "id of the practice that replaces this one. Required when status is 'superseded', null otherwise.",
      "type": ["string", "null"],
      "pattern": "^practice:[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "applies_to": {
      "description": "Scope of applicability. Empty arrays mean 'all'. Drives contextual surfacing on the platform.",
      "type": "object",
      "additionalProperties": false,
      "required": ["test_kinds", "chemistries", "cell_formats"],
      "properties": {
        "test_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "cycling", "capacity_check", "rate_capability", "quasi_ocv",
              "hppc", "ici", "gitt", "dcir", "eis", "impedance",
              "calendar_ageing", "formation", "rpt", "field", "duty_cycle",
              "wltp", "nedc", "sem", "characterization", "other"
            ]
          }
        },
        "chemistries": {
          "description": "Lowercase kebab-case chemistry or electrode-basis tokens (e.g. li-ion, lfp, nmc, graphite).",
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" }
        },
        "cell_formats": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["cylindrical", "prismatic", "pouch", "coin", "other"]
          }
        }
      }
    },
    "maturity": {
      "type": "string",
      "enum": ["proposal", "community-reviewed", "standard-aligned"]
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "orcid": {
            "anyOf": [
              { "type": "string", "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[0-9X]$" },
              { "type": "null" }
            ]
          },
          "affiliation": { "type": "string" }
        }
      }
    },
    "sources": {
      "description": "Structured provenance: the evidence this practice rests on. Every normative claim must trace to a source. Use role 'adapted' when text, figures, or tables are adapted from a source — that requires the source license and a note describing what was adapted.",
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Source" }
    },
    "related_protocols": {
      "description": "BattINFO test-protocol IRIs this practice informs or is derived from.",
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "created_at": { "type": "string", "format": "date" },
    "updated_at": { "type": "string", "format": "date" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "superseded" } } },
      "then": { "required": ["superseded_by"], "properties": { "superseded_by": { "type": "string" } } }
    }
  ],
  "$defs": {
    "Source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "title"],
      "anyOf": [{ "required": ["doi"] }, { "required": ["url"] }],
      "properties": {
        "role": {
          "description": "primary: the source the content is built on. background: context and history. adapted: text/figures/tables adapted from it (license + note required). data: dataset used. tool: software the document depends on.",
          "type": "string",
          "enum": ["primary", "background", "adapted", "data", "tool"]
        },
        "title": { "type": "string", "minLength": 1 },
        "authors": { "type": "string" },
        "year": { "type": "integer" },
        "venue": { "type": "string" },
        "doi": { "type": "string", "pattern": "^10\\." },
        "url": { "type": "string", "format": "uri" },
        "license": {
          "description": "License of the source material, e.g. CC-BY-4.0. Required for role 'adapted'.",
          "type": "string"
        },
        "accessed": {
          "description": "Date the source was consulted. Recommended for web sources.",
          "type": "string",
          "format": "date"
        },
        "note": {
          "description": "What was used from this source. Required for role 'adapted'.",
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": { "properties": { "role": { "const": "adapted" } }, "required": ["role"] },
          "then": { "required": ["license", "note"] }
        }
      ]
    }
  }
}
